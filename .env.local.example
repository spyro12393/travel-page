# ─────────────────────────────────────────────────────────────
# Required — Google Maps JavaScript API
# ─────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or select an existing one)
# 3. Enable "Maps JavaScript API"
# 4. Create an API key (restrict by HTTP referrer for security)
# 5. Add the key below
#
# Without this key the map sections show a placeholder message.
# Weather and currency features work without any API key.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
